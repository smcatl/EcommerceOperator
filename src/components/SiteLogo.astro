---
import SiteMark from './SiteMark.astro';

interface Props { variant?: 'header' | 'footer'; }
const { variant = 'header' } = Astro.props;
const isFooter = variant === 'footer';
---
{isFooter ? (
  <a href="/" class="nav-logo nav-logo-footer eo-wordmark" style="margin-bottom:.75rem; display:inline-flex;">
    <SiteMark style="background:rgba(0,191,165,0.08);" />
    <span class="nav-logo-text">
      <span class="logo-word-1" style="color:rgba(232,240,242,0.9);">ECOMMERCE</span>
      <span class="logo-word-2" style="color:#00BFA5;">OPERATOR</span>
    </span>
  </a>
) : (
  <a href="/" class="nav-logo nav-logo-header eo-wordmark">
    <SiteMark />
    <span class="nav-logo-text">
      <span class="logo-word-1">ECOMMERCE</span>
      <span class="logo-word-2">OPERATOR</span>
    </span>
  </a>
)}
