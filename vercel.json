{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "redirects": [
    {
      "source": "/recommends/shopify",
      "destination": "https://www.shopify.com/",
      "permanent": false
    },
    {
      "source": "/recommends/bigcommerce",
      "destination": "https://www.bigcommerce.com/",
      "permanent": false
    },
    {
      "source": "/recommends/klaviyo",
      "destination": "https://www.klaviyo.com/",
      "permanent": false
    },
    {
      "source": "/recommends/gorgias",
      "destination": "https://www.gorgias.com/",
      "permanent": false
    },
    {
      "source": "/recommends/triplewhale",
      "destination": "https://www.triplewhale.com/",
      "permanent": false
    },
    {
      "source": "/recommends/postscript",
      "destination": "https://postscript.io/",
      "permanent": false
    },
    {
      "source": "/recommends/recharge",
      "destination": "https://rechargepayments.com/",
      "permanent": false
    },
    {
      "source": "/recommends/yotpo",
      "destination": "https://www.yotpo.com/",
      "permanent": false
    },
    {
      "source": "/recommends/okendo",
      "destination": "https://www.okendo.io/",
      "permanent": false
    },
    {
      "source": "/recommends/semrush",
      "destination": "https://www.semrush.com/",
      "permanent": false
    },
    {
      "source": "/recommends/hubspot",
      "destination": "https://www.hubspot.com/",
      "permanent": false
    },
    {
      "source": "/recommends/omnisend",
      "destination": "https://www.omnisend.com/",
      "permanent": false
    },
    {
      "source": "/recommends/jotform",
      "destination": "https://www.jotform.com/",
      "permanent": false
    },
    {
      "source": "/recommends/tidio",
      "destination": "https://www.tidio.com/",
      "permanent": false
    },
    {
      "source": "/recommends/wpengine",
      "destination": "https://wpengine.com/",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 2"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 3"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 4"
    },
    {
      "path": "/api/refill-queue",
      "schedule": "0 13 * * 0"
    }
  ]
}
